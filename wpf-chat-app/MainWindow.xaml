<Window x:Class="wpf_chat_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:wpf_chat_app"
        mc:Ignorable="d"
        AllowsTransparency="True"
        FontSize="15"
        Height="768"
        Width="1250"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Title="chat app">
    <Border
        Background="WhiteSmoke">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" /><!-- title bar -->
                <RowDefinition Height="auto" /><!-- tool bar -->
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/><!-- contacts -->
                <ColumnDefinition Width="*"/><!-- message -->
            </Grid.ColumnDefinitions>
            <!-- Title bar -->
            <Border
                Background="#49a087"
                Grid.ColumnSpan="3">
                <Grid>
                    <TextBlock
                        Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                        HorizontalAlignment="left"
                        Margin="15, 0"
                        VerticalAlignment="center"
                        Foreground="White"
                        FontSize="22"
                        FontWeight="Bold"
                        />

                    <StackPanel 
                        HorizontalAlignment="Right"
                        Margin="20, 0"
                        Orientation="Horizontal">
                        <Button x:Name="btnMinimize"
                                Content="{StaticResource minimize}"
                                Style="{StaticResource IconButtonStyle}"
                                Click="btnMinimize_Click"/>
                        <Button x:Name="btnMaximaze"
                                Content="{StaticResource maximize}"
                                Style="{StaticResource IconButtonStyle}"
                                Click="btnMaximaze_Click"/>
                        <Button x:Name="btnClose"
                                Content="{StaticResource close}"
                                Style="{StaticResource IconButtonStyle}"                                
                                Click="btnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tool bar -->
            <Menu Grid.Row="1" Grid.ColumnSpan="2">
                <MenuItem Header="Datoteka">
                    <MenuItem Header="Izhod"/>
                </MenuItem>
                <MenuItem Header="Stiki">
                    <MenuItem Header="Dodaj stik"/>
                    <MenuItem Header="Izbriši stik"/>
                </MenuItem>
                <MenuItem Header="Orodja">
                    <MenuItem Header="Nastavitve"/>
                </MenuItem>
            </Menu>

            <!-- Contact list -->
            <Grid Grid.Row="2" MaxWidth="306" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><!-- header -->
                    <RowDefinition Height="Auto"/><!-- search bar -->
                    <RowDefinition Height="*"/><!-- contacts -->
                </Grid.RowDefinitions>

                <!-- header -->
                <Grid Margin="15,10,15,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock 
                        Text="Stiki"
                        FontSize="20"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"/>

                    <Button
                        x:Name="ChatResearchButton"
                        Grid.Column="1"
                        Content="{StaticResource search}"
                        Style="{StaticResource IconButtonStyle}"/>
                </Grid>

                <!-- search bar -->
                <Border 
                    Grid.Row="1"
                    Background="#dce1de"
                    CornerRadius="8"
                    Margin="10"
                    Height="40">
                    <TextBox 
                        Name="SearchQuery"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="12,0"
                        VerticalContentAlignment="Center"
                        Text="Isci..."/>
                </Border>

                <!-- contacts -->
                <ListBox 
                    x:Name="ContactsList"
                    Grid.Row="2"
                    ItemsSource="{Binding Contacts}" 
                    Background="Transparent"
                    BorderThickness="0"
                    SelectionMode="Single"
                    SelectionChanged="ContactsList_SelectionChanged">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5" Width="80" HorizontalAlignment="Center">
                                <Ellipse Width="60" Height="60" Stroke="Gray" StrokeThickness="1">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding imagePath}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{Binding name}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
            
            <!-- message -->
            <Grid Grid.Row="2" Grid.Column="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><!-- header -->
                    <RowDefinition Height="*"/><!-- chat -->
                    <RowDefinition Height="Auto"/><!-- send message -->
                </Grid.RowDefinitions>

                <!-- header -->
                <TextBlock x:Name="ChatHeader" 
                    Text=""
                    FontWeight="Bold"
                    FontSize="16"
                    Margin="0,0,0,10"/>

                <!-- chat -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ChatItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="msgBorder"
                                    Background="LightGray"
                                    CornerRadius="10"
                                    Padding="10"
                                    Margin="5"
                                    HorizontalAlignment="Left"
                                    MaxWidth="300">

                                    <TextBlock Text="{Binding text}" TextWrapping="Wrap"/>

                                </Border>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding isSentByUser}" Value="True">
                                        <Setter TargetName="msgBorder" Property="Background" Value="LightBlue"/>
                                        <Setter TargetName="msgBorder" Property="HorizontalAlignment" Value="Right"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- send message -->
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="MessageBox" Height="30" Margin="0,0,5,0"/>
                    <Button Grid.Column="1"
                        Content="Pošlji"
                        Width="80"
                        Click="SendButton_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
