<Window x:Class="wpf_chat_app.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:wpf_chat_app"
        mc:Ignorable="d"
        Title="Window1" Height="350" Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        <TextBlock 
            Grid.Column="1"
            Text="Dodaj Stik"
            FontSize="20"
            FontWeight="DemiBold"
            VerticalAlignment="Bottom"
            HorizontalAlignment="left"/>

        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Margin="0, 20" >
            <StackPanel>
                <TextBlock>Ime</TextBlock>
                <Border BorderBrush="Black"  BorderThickness="1" CornerRadius="5" Padding="4, 1">
                    <TextBox
                            x:Name="input_ime"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalContentAlignment="Center"
                            FontSize="13"
                            Text="Janez"/>
                </Border>
            </StackPanel>
            <StackPanel Margin="0, 20">
                <TextBlock>Mail</TextBlock>
                <Border BorderBrush="Black"  BorderThickness="1" CornerRadius="5" Padding="4, 1">
                    <TextBox
                            x:Name="input_mail"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalContentAlignment="Center"
                            FontSize="13"
                            Text="Janez@gmail.com"/>
                </Border>
            </StackPanel>
            <StackPanel Margin="0, 100, 0, 0">
                <Button Click="Button_AddContact">Dodaj stik</Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
